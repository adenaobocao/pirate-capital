# ── the brain ────────────────────────────────────────────────────────────────
# Default: any OpenAI compatible endpoint. Set BASE + MODEL (+ KEY unless local)
# and no other provider is needed. Free friendly examples:
#
#   OpenRouter (free models exist, look for the :free suffix)
#     PIRATE_API_BASE=https://openrouter.ai/api/v1
#     PIRATE_API_MODEL=deepseek/deepseek-chat-v3-0324:free
#     PIRATE_API_KEY=sk-or-...
#
#   Groq (fast, generous free tier)
#     PIRATE_API_BASE=https://api.groq.com/openai/v1
#     PIRATE_API_MODEL=llama-3.3-70b-versatile
#     PIRATE_API_KEY=gsk_...
#
#   Gemini via its OpenAI endpoint (free tier)
#     PIRATE_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
#     PIRATE_API_MODEL=gemini-2.0-flash
#     PIRATE_API_KEY=AI...
#
#   Ollama, local and 100% free (no key needed)
#     PIRATE_API_BASE=http://localhost:11434/v1
#     PIRATE_API_MODEL=qwen2.5:7b
#
PIRATE_API_BASE=
PIRATE_API_MODEL=
PIRATE_API_KEY=

# Fallback brain: the Anthropic API (used only when PIRATE_API_BASE is not set)
# ANTHROPIC_API_KEY=
# PIRATE_MODEL=claude-opus-4-8
# PIRATE_CROWD_MODEL=claude-opus-4-8

# ── the wire (real-world signals) ────────────────────────────────────────────
# These make the pirates trade on news/policy/sentiment, not just price.
# KEYLESS sources always run (GDELT news tone, Federal Register tariffs,
# alternative.me crypto fear/greed). Add these FREE keys to strengthen the
# per-ticker signal (all instant, no KYC):
#   Alpha Vantage news sentiment (25/day): https://www.alphavantage.co/support/#api-key
#     ALPHAVANTAGE_KEY=
#   Finnhub analyst trends (60/min):       https://finnhub.io/register
#     FINNHUB_KEY=
#   FRED macro/rates (raises limits):      https://fredaccount.stlouisfed.org
#     FRED_KEY=
# ALPHAVANTAGE_KEY=
# FINNHUB_KEY=
# FRED_KEY=

# ── the ship ─────────────────────────────────────────────────────────────────
# Dashboard port (optional, default: 4243)
# PIRATE_PORT=4243
